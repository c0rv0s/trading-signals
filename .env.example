TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Run once and exit. Keep true for Railway cron jobs.
RUN_ONCE=true

# Comma-separated assets. Defaults match the bullish watchlist.
WATCHLIST=ZEC,HYPE

# Data sources are configurable per asset.
# binance_spot uses symbols like ZECUSDT.
# hyperliquid_perp uses coins like HYPE.
ZEC_PROVIDER=hyperliquid_perp
ZEC_MARKET=ZEC
HYPE_PROVIDER=hyperliquid_perp
HYPE_MARKET=HYPE

# Strategy controls.
STRATEGY=swing_breakout
LOOP_SECONDS=3600
ALERT_COOLDOWN_HOURS=24
MIN_SCORE_TO_ALERT=8
MAX_STOP_PCT=0.025
MIN_STOP_PCT=0.008
MAX_DISTANCE_FROM_HOURLY_EMA_PCT=0.035
LEVERAGE=5
MAX_MARGIN_LOSS_PCT=0.12
MAINTENANCE_MARGIN_PCT=0.005
LIQUIDATION_BUFFER_PCT=0.01
DAILY_LOOKBACK_DAYS=180
HOURLY_LOOKBACK_HOURS=500
STATE_FILE=.signal_state.json
